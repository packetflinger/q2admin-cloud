{{define "server-view"}}
{{template "header" .}}

		<h1 class="h3 mb-3">{{.Title}}</h1>
		<div class="row">
			<div>
				<form method="get" action="/search/{{.Frontend.UUID}}">
					<div class="input-group mb-3">
						<input type="text" name="q" class="form-control" placeholder="Search IPs, player names, more" aria-label="Example text with button addon" aria-describedby="searchbutton">
						<button class="btn btn-primary" type="submit" id="searchbutton">Search</button>
					</div>
				</form>
			</div>
		</div>

		<div class="row">
			<div class="col-12 col-sm-4 gy-3">
				<div class="card">
					<div class="card-header">
						<h4>Settings <a href="#" data-bs-toggle="modal" data-bs-target="#edit-server-modal"><i class="float-end" data-feather="edit-2"></i></a></h4>
					</div>
					<div class="card-body">
						<table class="table">
							<tr><td>ID:</td><td><span class="font-monospace">{{.Frontend.UUID}}</span> <a href="#" data-bs-toggle="modal" data-bs-target="#changeuuid"><i data-feather="refresh-cw"></i></a></td></tr>
							<tr><td>Address:</td><td><a href="quake2://{{.Frontend.IPAddress}}:{{.Frontend.Port}}">{{.Frontend.IPAddress}}:{{.Frontend.Port}}</a></td></tr>
							<tr><td></td><td>
								<div>{{ .Frontend.Enabled | yesnoemoji }} Enabled</div>
								<div>{{ .Frontend.AllowTeleport | yesnoemoji }} Teleport Allowed</div>
								<div>{{ .Frontend.AllowInvite | yesnoemoji }} Invite Allowed</div>
							</td></tr>
						</table>
					</div>
				</div>
			</div>

			<div class="col-12 col-sm-4 gy-3">
				<div class="card">
					<div class="card-header"><h4>Keys <a href="#" data-bs-toggle="modal" data-bs-target="#key-explain-modal"><i class="float-end" data-feather="help-circle"></i></a></h4></div>
					<div class="card-body">
						{{ if .Frontend.PublicKeyData }}<div><a href="#" data-bs-toggle="modal" data-bs-target="#publickey">View/Edit Public Key</a></div>
						{{ else }}<div><a href="#" data-bs-toggle="modal" data-bs-target="#publickey">Add Public Key</a></div>{{ end }}
						<div><a href="/sv/{{ .Frontend.UUID }}/{{ .Frontend.Name }}/generate-keys">Generate Key Pair</a></div>
					</div>
				</div>
			</div>
{{if .Frontend.Connected}}
			<div class="col-12 col-sm-4 gy-3">
				<div class="card">
					<div class="card-header">
						<h4>Frontend Status</h4>
					</div>
					<div class="card-body">
						<table class="table">
							<tr><td>Peer Address: </td><td><span class="font-monospace">{{.Frontend.Connection.RemoteAddr.String}}</span> {{if .Frontend.Encrypted}}<i data-feather="lock"></i>{{end}}</td></tr>
							<tr><td>Last connected: </td><td>{{.Frontend.ConnectTime | ago}}</td></tr>
							<tr><td>Flags: </td><td>{{ index .Frontend.ServerVars "dmflags" | dmflags}}</td></tr>
							<tr><td>Current Map: </td><td><span class="font-monospace">{{ .Frontend.CurrentMap }}</span></td></tr>
							<tr><td>Teleports: </td><td>{{ .Frontend.TeleportCount }}</td></tr>
							<tr><td>Invites: </td><td>{{ .Frontend.Invites.UseCount }}</td></tr>
						</table>
					</div>
				</div>
			</div>
			<div class="col-12 col-sm-4 gy-3">
				<div class="card">
					<div class="card-header"><h4>Current Players [{{ .Frontend.PlayerCount}}/{{ .Frontend.MaxPlayers}}]</h4></div>
					<div class="card-body">
					{{ if .Frontend.PlayerCount}}
					  {{ range $index, $val := .Frontend.Players}}
					    {{ if .IP }}
						<p><a href="/sv/{{.Frontend.UUID}}/{{.Frontend.Name}}/player/{{$index}}">{{ $val.Name }}</a> [{{$val.IP}}]</p>
					    {{ end }}
					  {{ end }}
					{{ else }}
					  <p>none</p>
					{{ end }}
					</div>
				</div>
			</div>
			<div class="col-12 col-sm-4 gy-3">
				<div class="card">
					<div class="card-header"><h4>Server Vars</h4></div>
					<div class="card-body">
{{ range $key, $value := .Frontend.ServerVars }}
						<div class="row"><div class="col"><strong>{{ $key }}</strong>:</div><div class="col">{{ $value }}</div></div>
{{ end }}
					</div>
				</div>
			</div>
			<div class="col-12 col-sm-4 gy-3">
				<div class="card">
					<div class="card-header"><h4>Actions</h4></div>
					<div class="card-body">
						<div><i data-feather="command"></i> <a href="#" data-bs-toggle="modal" data-bs-target="#runcmd">Run a command</a></div>
						<div><i data-feather="map"></i> <a href="#">Change the map</a> [{{ .Frontend.CurrentMap}}]</div>
						<div><i data-feather="terminal"></i> <a href="/sv/{{.Frontend.UUID}}/{{.Frontend.Name}}/console">Console</a></div>
					</div>
				</div>
			</div>
{{else}}
			<div class="col gy-3">
				<div class="card">
					<div class="card-header">
						Quake 2 server not connected
					</div>
				</div>
			</div>
{{end}}
			<div class="col-12 col-sm-4 gy-3">
				<div class="card">
					<div class="card-header"><h4>Rules <a class="float-end" href="#"><i data-feather="file-plus"></i></a></h4></div>
					<div class="card-body">
					{{ range .Frontend.Rules }}
						<div><a href="/rules/{{ .GetUuid }}/view">{{ .GetDescription }}</a></div>
					{{ end }}
					</div>
				</div>
			</div>
		</div>
		<div class="row">
			<div class="col gy-4">
				<p><button class="btn btn-danger {{ if .Frontend.DeleteProtect }}disabled{{ end }}" data-bs-toggle="modal" data-bs-target="#deletefrontend">Delete this Frontend</button></p>
			</div>
		</div>
	</div>
	

	<div class="modal fade" id="edit-server-modal" tabindex="-1" aria-labelledby="edit-server-modal" aria-hidden="true">
		<div class="modal-dialog">
			<div class="modal-content">
				<form method="post" action="/sv/{{.Frontend.UUID}}/{{.Frontend.Name}}/edit">
					<div class="modal-header">
						<h5 class="modal-title">Edit Frontend Settings</h5>
						<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
					</div>
					<div class="modal-body">
						<p>
							<b><label for="servername" class="form-label">Frontend Name</label></b>
							<input type="text" class="form-control" id="servername" name="servername" placeholder="pf-tdm-antarctica" value="{{.Frontend.Name}}">
						</p>
						<p>
							<b><label for="serveraddr" class="form-label">Frontend Address</label></b>
							<input type="text" class="form-control" id="serveraddr" name="serveraddr" placeholder="100.64.55.4:27910" value="{{.Frontend.IPAddress}}:{{.Frontend.Port}}">
						</p>
						<p>
							<div class="form-check form-switch">
								<input class="form-check-input" type="checkbox" id="switchEnabled" name="switchenabled" {{.Frontend.Enabled | checked}}>
								<label class="form-check-label" for="switchEnabled">Enabled</label>
							</div>
							<div class="form-check form-switch">
								<input class="form-check-input" type="checkbox" id="switchTeleport" name="switchteleport" {{.Frontend.AllowTeleport | checked}}>
								<label class="form-check-label" for="switchTeleport">Allow player teleporting to other frontends</label>
							</div>
							<div class="form-check form-switch">
								<input class="form-check-input" type="checkbox" id="switchInvite" name="switchinvite" {{.Frontend.AllowInvite | checked}}>
								<label class="form-check-label" for="switchInvite">Allow player invite broadcasts</label>
							</div>
						</p>
						<p>
						    <div class="form-check form-switch">
								<input class="form-check-input" type="checkbox" id="switchProtect" name="switchprotect" {{.Frontend.DeleteProtect | checked}}>
								<label class="form-check-label" for="switchProtect">Delete Protection</label>
							</div>
						</p>
					</div>
					<div class="modal-footer">
						<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
						<button type="submit" class="btn btn-primary">Save</button>
					</div>
					<input type="hidden" name="uuid" value="{{.Frontend.UUID}}">
					<!-- <input type="hidden" name="srvname" value="{{.Frontend.Name}}"> -->
					<input type="hidden" name="action" value="SaveFrontendSettings">
				</form>
			 </div>
		</div>
	</div>

	<div class="modal fade" id="changeuuid" tabindex="-1" aria-labelledby="changeuuid" aria-hidden="true">
		<div class="modal-dialog">
			<div class="modal-content">
				<div class="modal-header">
					<h5 class="modal-title">Generate new unique ID?</h5>
					<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
				</div>
				<div class="modal-body">
					<p>Are you sure you want to change your frontend's UUID?</p>
					<p>Any active frontend using the current UUID will disconnect from CloudAdmin and require an update to its config. This change can't be reverted as UUIDs are auto-generated.</p>
					<p>The primary use-case for regenerating IDs is when someone else knows the ID and is trying to use it.</p>
				</div>
				<div class="modal-footer">
					<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">No!</button>
					<a href="/sv/{{.Frontend.UUID}}/{{.Frontend.Name}}/changeuuid" type="button" class="btn btn-primary">Sure</a>
				</div>
			 </div>
		</div>
	</div>

	<div class="modal fade" id="runcmd" tabindex="-1" aria-labelledby="runcmd" aria-hidden="true">
		<div class="modal-dialog">
			<div class="modal-content">
				<div class="modal-header">
					<h5 class="modal-title">Run a command</h5>
					<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
				</div>
				<div class="modal-body">
					<div class="mb-3">
						<label for="cmdinput" class="form-label">Command</label>
						<input type="text" class="form-control" id="cmdinput" placeholder="">
					</div>
					<div class="mb-3">
						<label for="cmdoutput" class="form-label">Output</label>
						<textarea class="form-control" id="cmdoutput" rows="3"></textarea>
					</div>
					<div>
						<button type="button" class="btn btn-primary float-end">Run</button>
					</div>
				</div>
				<div class="modal-footer">
					<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
				</div>
			 </div>
		</div>
	</div>

	<div class="modal fade" id="publickey" tabindex="-1" aria-labelledby="publickey" aria-hidden="true">
		<div class="modal-dialog">
			<div class="modal-content">
				<form action="/sv/{{.Frontend.UUID}}/{{.Frontend.Name}}/manage-keys" method="post">
					<div class="modal-header">
						<h5 class="modal-title">Frontend Public Key</h5>
						<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
					</div>
					<div class="modal-body">
						<div class="mb-3">
							<label for="keydata" class="form-label">Key Data:</label>
							<textarea style="height: 300px;" class="form-control" id="keydata" name="keydata" placeholder="">{{ .Frontend.PublicKeyData }}</textarea>
						</div>
					</div>
					<div class="modal-footer">
						<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
						<button type="submit" class="btn btn-primary">Save</button>
					</div>
					<input type="hidden" name="uuid" value="{{.Frontend.UUID}}">
					<input type="hidden" name="srvname" value="{{.Frontend.Name}}">
					<input type="hidden" name="action" value="SaveKey">
				</form>
			</div>
		</div>
	</div>

	<div class="modal fade" id="key-explain-modal" tabindex="-1" aria-labelledby="key-explain-modal" aria-hidden="true">
		<div class="modal-dialog">
			<div class="modal-content">
				<div class="modal-header">
					<h5 class="modal-title">Keys?</h5>
					<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
				</div>
				<div class="modal-body">
					<h5>How does Q2Admin use them?</h5>
					<p>
						Q2Admin uses asymmetric encryption keys (public/private pairs) for authentication and key exchange.
					</p>
					<p>
						You store a private key securely along with your Quake 2 server locally, and provide 
						the public key here. When your Quake 2 server initiates a connection to this CloudAdmin server, 
						the server will challenge your server with data encrypted with the public key. Only the 
						complementary private key will be able to decrypt this data, proving this is the intended 
						server and allowing the connection.
					</p>
					<p>
						If the local Q2Admin is configured for an encrypted connection (default behavior), the public key
						provided is used for encrypting an ephemeral symmetric session key used for securing the data
						exchanged between the CloudAdmin and your Quake 2 server. These sessions keys are automatically
						rotated every hour or so.
					</p>
					<h5>Can I generate my own keys on my end?</h5>
					<p>
						Yes you can, and you should. It's considered insecure to transmit private keys between devices over
						untrusted networks. The Generate Keys function is for convenience. Generate these with the openssl program:
					</p>
					<p>
						<div>For the private key "private.pem"</div>
						<code>
						$ openssl genpkey -out private.pem -algorithm RSA -pkeyopt rsa_keygen_bits:2048
						</code>
					</p>
					<p>
						<div>For the complementary public key "public.pem"</div>
						<code>
						$ openssl pkey -in private.pem -pubout -out public.pem
						</code>
					</p>
					<p>
						Then click the <b>View/Edit Public Key</b> link and simply paste the contents of the public key.
					</p>
				</div>
				<div class="modal-footer">
					<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Okay</button>
				</div>
			 </div>
		</div>
	</div>

	<div class="modal fade" id="deletefrontend" tabindex="-1" aria-labelledby="deletefrontend" aria-hidden="true">
		<div class="modal-dialog">
			<div class="modal-content">
				<div class="modal-header">
					<h5 class="modal-title">Delete Frontend "{{ .Frontend.Name }}"?</h5>
					<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
				</div>
				<div class="modal-body">
					<p>Are you sure you want to delete this frontend?</p>
					<p>Any historical data/statistics/logs will be automatically deleted and this frontend will no longer be a valid teleport destination.</p>
					<p><b>This action cannot be undone!</b> (but you can certainly recreate it)
				</div>
				<div class="modal-footer">
					<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">NO!</button>
					<a href="/sv/{{.Frontend.UUID}}/{{.Frontend.Name}}/delete" type="button" class="btn btn-danger"><b>Yes, delete please</b></a>
				</div>
			 </div>
		</div>
	</div>
{{template "footer" .}}
{{end}}